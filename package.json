{
  "name": "proof-of-possible",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "A local-first assisted experiment compiler.",
  "scripts": {
    "test": "node --test tests/*.test.mjs && node scripts/check-static.mjs",
    "test:e2e": "npm run build && playwright test",
    "build": "node scripts/build.mjs",
    "check": "node --check src/core.mjs && node --check src/app.mjs && node --check scripts/*.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1"
  }
}
